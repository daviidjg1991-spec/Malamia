  file_change {
    absolute_path_uri: "file:///src/components/ScheduleGrid.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Employee, Category, Shift } from \'../types\';\nimport { DAYS_OF_WEEK } from \'../constants\';\nimport { Clock, Plus, X } from \'lucide-react\';\nimport { v4 as uuidv4 } from \'uuid\';\nimport { calculateShiftHours } from \'../utils\';\n\ninterface ScheduleGridProps {\n  employees: Employee[];\n  categories: Category[];\n  shifts: Shift[];\n  setShifts: React.Dispatch<React.SetStateAction<Shift[]>>;\n}\n\nexport function ScheduleGrid({ employees, categories, shifts, setShifts }: ScheduleGridProps) {\n  const [modalOpen, setModalOpen] = useState(false);\n  const [selectedCell, setSelectedCell] = useState<{empId: string, dayIdx: number} | null>(null);\n  const [startTime, setStartTime] = useState(\'09:00\');\n  const [endTime, setEndTime] = useState(\'17:00\');\n  const [selectedCategoryId, setSelectedCategoryId] = useState<string>(\'\');\n\n  const openModal = (empId: string, dayIdx: number) => {\n    setSelectedCell({ empId, dayIdx });\n    if (categories.length > 0 && !selectedCategoryId) {\n      setSelectedCategoryId(categories[0].id);\n    }\n    setModalOpen(true);\n  };\n\n  const handleAddShift = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!selectedCell || !selectedCategoryId) return;\n\n    const newShift: Shift = {\n      id: uuidv4(),\n      employeeId: selectedCell.empId,\n      dayIndex: selectedCell.dayIdx,\n      categoryId: selectedCategoryId,\n      startTime,\n      endTime\n    };\n\n    setShifts([...shifts, newShift]);\n    setModalOpen(false);\n  };\n\n  const removeShift = (shiftId: string) => {\n    setShifts(shifts.filter(s => s.id !== shiftId));\n  };\n\n  return (\n    <div className=\"bg-white p-6 rounded-lg shadow-sm border border-slate-200 overflow-x-auto\">\n      <div className=\"flex justify-between items-center mb-6\">\n        <h2 className=\"text-xl font-bold text-slate-800\">Horario Semanal</h2>\n        <div className=\"text-sm text-slate-500\">\n          Haz clic en una celda para a\303\261adir un turno.\n        </div>\n      </div>\n      \n      {employees.length === 0 ? (\n        <div className=\"text-center py-12 text-slate-500 bg-slate-50 rounded-lg border border-dashed border-slate-300\">\n          <p>A\303\261ade empleados para comenzar a crear el horario.</p>\n        </div>\n      ) : (\n        <table className=\"w-full border-collapse min-w-[800px]\">\n          <thead>\n            <tr>\n              <th className=\"border border-slate-200 bg-slate-100 p-3 text-left w-48 text-slate-700 font-semibold sticky left-0 z-10\">Empleado</th>\n              {DAYS_OF_WEEK.map((day, idx) => (\n                <th key={idx} className=\"border border-slate-200 bg-slate-50 p-3 text-center text-slate-700 font-medium w-40\">\n                  {day}\n                </th>\n              ))}\n            </tr>\n          </thead>\n          <tbody>\n            {employees.map(emp => (\n              <tr key={emp.id} className=\"hover:bg-slate-50/50\">\n                <td className=\"border border-slate-200 p-3 font-medium text-slate-800 bg-white sticky left-0 z-10 shadow-[1px_0_0_0_#e2e8f0]\">\n                  {emp.name}\n                  <div className=\"text-xs text-slate-500 mt-1 font-normal\">\n                    {emp.hourlyRate} \342\202\254/h\n                  </div>\n                </td>\n                {DAYS_OF_WEEK.map((_, dayIdx) => {\n                  const cellShifts = shifts.filter(s => s.employeeId === emp.id && s.dayIndex === dayIdx);\n                  return (\n                    <td \n                      key={dayIdx} \n                      className=\"border border-slate-200 p-2 align-top h-24 hover:bg-blue-50/30 cursor-pointer group transition-colors relative\"\n                      onClick={(e) => {\n                        // Prevent opening modal if clicked on a shift item instead of the cell background\n                        if ((e.target as HTMLElement).closest(\'.shift-item\')) return;\n                        openModal(emp.id, dayIdx);\n                      }}\n                    >\n                      <div className=\"flex flex-col gap-2 h-full\">\n                        {cellShifts.map(shift => {\n                          const cat = categories.find(c => c.id === shift.categoryId);\n                          const hours = calculateShiftHours(shift.startTime, shift.endTime);\n                          return (\n                            <div \n                              key={shift.id} \n                              className={`shift-item relative ${cat?.color || \'bg-slate-500\'} text-white p-2 rounded shadow-sm text-sm group/shift animate-in fade-in zoom-in-95 duration-200`}\n                            >\n                              <div className=\"flex justify-between items-start\">\n                                <span className=\"font-semibold text-xs opacity-90\">{cat?.name || \'Turno\'}</span>\n                                <button \n                                  onClick={() => removeShift(shift.id)}\n                                  className=\"opacity-0 group-hover/shift:opacity-100 hover:bg-white/20 rounded p-0.5 transition-all text-white -mt-1 -mr-1\"\n                                >\n                                  <X size={14} />\n                                </button>\n                              </div>\n                              <div className=\"flex items-center gap-1 mt-1 font-mono text-xs\">\n                                <Clock size={12} className=\"opacity-80\" />\n                                {shift.startTime} - {shift.endTime}\n                              </div>\n                              <div className=\"text-[10px] mt-1 opacity-80 border-t border-white/20 pt-1\">\n                                {hours.toFixed(2)}h\n                              </div>\n                            </div>\n                          );\n                        })}\n                        <div className=\"flex-1 min-h-[20px] flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity\">\n                            <Plus size={20} className=\"text-blue-400\" />\n                        </div>\n                      </div>\n                    </td>\n                  );\n                })}\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      )}\n\n      {/* Modal for adding shifts */}\n      {modalOpen && (\n        <div className=\"fixed inset-0 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center z-50 animate-in fade-in duration-200\">\n          <div className=\"bg-white rounded-xl shadow-2xl p-6 w-full max-w-md animate-in slide-in-from-bottom-4 duration-300\">\n            <div className=\"flex justify-between items-center mb-5\">\n              <h3 className=\"text-xl font-bold text-slate-800\">A\303\261adir Turno</h3>\n              <button onClick={() => setModalOpen(false)} className=\"text-slate-400 hover:text-slate-600\">\n                <X size={24} />\n              </button>\n            </div>\n            \n            {categories.length === 0 ? (\n              <div className=\"p-4 bg-orange-50 text-orange-800 rounded border border-orange-200 mb-4\">\n                Primero debes crear al menos una categor\303\255a/bloque en la secci\303\263n superior para poder asignar turnos.\n              </div>\n            ) : (\n              <form onSubmit={handleAddShift} className=\"space-y-4\">\n                <div>\n                  <label className=\"block text-sm font-medium text-slate-700 mb-1\">Categor\303\255a</label>\n                  <select \n                    value={selectedCategoryId}\n                    onChange={(e) => setSelectedCategoryId(e.target.value)}\n                    className=\"w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none\"\n                    required\n                  >\n                    {categories.map(cat => (\n                      <option key={cat.id} value={cat.id}>{cat.name}</option>\n                    ))}\n                  </select>\n                </div>\n                \n                <div className=\"grid grid-cols-2 gap-4\">\n                  <div>\n                    <label className=\"block text-sm font-medium text-slate-700 mb-1\">Hora Entrada</label>\n                    <input \n                      type=\"time\" \n                      value={startTime}\n                      onChange={(e) => setStartTime(e.target.value)}\n                      className=\"w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none\"\n                      required\n                    />\n                  </div>\n                  <div>\n                    <label className=\"block text-sm font-medium text-slate-700 mb-1\">Hora Salida</label>\n                    <input \n                      type=\"time\" \n                      value={endTime}\n                      onChange={(e) => setEndTime(e.target.value)}\n                      className=\"w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none\"\n                      required\n                    />\n                  </div>\n                </div>\n                \n                <div className=\"text-sm text-slate-500 italic mt-1\">\n                  * Si la hora de salida es menor que la de entrada, se considerar\303\241 turno nocturno (pasa al d\303\255a siguiente).\n                </div>\n\n                <div className=\"mt-6 flex justify-end gap-3 pt-4 border-t border-slate-100\">\n                  <button \n                    type=\"button\" \n                    onClick={() => setModalOpen(false)}\n                    className=\"px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg transition-colors\"\n                  >\n                    Cancelar\n                  </button>\n                  <button \n                    type=\"submit\"\n                    className=\"px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors shadow-sm\"\n                  >\n                    Guardar Turno\n                  </button>\n                </div>\n              </form>\n            )}\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
