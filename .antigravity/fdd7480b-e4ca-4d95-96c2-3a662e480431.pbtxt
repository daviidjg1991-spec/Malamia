    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Employee } from \'../types\';\nimport { formatCurrency } from \'../utils\';\nimport { Plus, Trash2 } from \'lucide-react\';\nimport { v4 as uuidv4 } from \'uuid\';\n\ninterface EmployeesProps {\n  employees: Employee[];\n  setEmployees: React.Dispatch<React.SetStateAction<Employee[]>>;\n}\n\nexport function Employees({ employees, setEmployees }: EmployeesProps) {\n  const [name, setName] = useState(\'\');\n  const [rate, setRate] = useState(\'\');\n\n  const handleAdd = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!name.trim() || !rate) return;\n    \n    setEmployees([\n      ...employees,\n      { id: uuidv4(), name: name.trim(), hourlyRate: parseFloat(rate) }\n    ]);\n    setName(\'\');\n    setRate(\'\');\n  };\n\n  const removeEmployee = (id: string) => {\n    setEmployees(employees.filter(emp => emp.id !== id));\n  };\n\n  return (\n    <div className=\"bg-white p-6 rounded-lg shadow-sm border border-slate-200\">\n      <h2 className=\"text-xl font-bold text-slate-800 mb-4\">Gesti\303\263n de Empleados</h2>\n      \n      <form onSubmit={handleAdd} className=\"flex gap-2 mb-6\">\n        <input \n          type=\"text\" \n          placeholder=\"Nombre del empleado\" \n          value={name}\n          onChange={(e) => setName(e.target.value)}\n          className=\"flex-1 px-3 py-2 border border-slate-300 rounded focus:ring-2 focus:ring-blue-500 outline-none\"\n        />\n        <div className=\"relative\">\n          <input \n            type=\"number\" \n            placeholder=\"0.00\"\n            step=\"0.01\" \n            min=\"0\"\n            value={rate}\n            onChange={(e) => setRate(e.target.value)}\n            className=\"w-28 pl-8 pr-3 py-2 border border-slate-300 rounded focus:ring-2 focus:ring-blue-500 outline-none\"\n          />\n          <span className=\"absolute left-3 top-2.5 text-slate-500\">\342\202\254</span>\n        </div>\n        <button \n          type=\"submit\"\n          className=\"bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded flex items-center gap-2 transition-colors\"\n        >\n          <Plus size={18} />\n          A\303\261adir\n        </button>\n      </form>\n\n      <div className=\"space-y-2 max-h-64 overflow-y-auto\">\n        {employees.length === 0 ? (\n          <p className=\"text-sm text-slate-500 italic text-center py-4\">No hay empleados registrados.</p>\n        ) : (\n          employees.map(emp => (\n            <div key={emp.id} className=\"flex justify-between items-center p-3 bg-slate-50 rounded border border-slate-100\">\n              <span className=\"font-medium text-slate-700\">{emp.name}</span>\n              <div className=\"flex items-center gap-4\">\n                <span className=\"text-slate-600 bg-white px-2 py-1 rounded border shadow-sm text-sm\">\n                  {formatCurrency(emp.hourlyRate)} / hora\n                </span>\n                <button \n                  onClick={() => removeEmployee(emp.id)}\n                  className=\"text-red-500 hover:text-red-700 p-1 rounded hover:bg-red-50 transition-colors\"\n                >\n                  <Trash2 size={18} />\n                </button>\n              </div>\n            </div>\n          ))\n        )}\n      </div>\n    </div>\n  );\n}\n"
    }
