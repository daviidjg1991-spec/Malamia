          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  if (cleaned.length === 3) return `0${cleaned.slice(0, 1)}:${cleaned.slice(1, 3)}`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
