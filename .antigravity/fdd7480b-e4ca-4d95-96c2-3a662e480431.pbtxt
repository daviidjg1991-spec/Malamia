    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Category } from \'../types\';\nimport { CATEGORY_COLORS } from \'../constants\';\nimport { Plus, Trash2, Tag } from \'lucide-react\';\nimport { v4 as uuidv4 } from \'uuid\';\n\ninterface CategoriesProps {\n  categories: Category[];\n  setCategories: React.Dispatch<React.SetStateAction<Category[]>>;\n}\n\nexport function Categories({ categories, setCategories }: CategoriesProps) {\n  const [name, setName] = useState(\'\');\n  const [selectedColor, setSelectedColor] = useState(CATEGORY_COLORS[0]);\n\n  const handleAdd = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!name.trim()) return;\n    \n    setCategories([\n      ...categories,\n      { id: uuidv4(), name: name.trim(), color: selectedColor }\n    ]);\n    setName(\'\');\n  };\n\n  const removeCategory = (id: string) => {\n    setCategories(categories.filter(cat => cat.id !== id));\n  };\n\n  return (\n    <div className=\"bg-white p-6 rounded-lg shadow-sm border border-slate-200\">\n      <h2 className=\"text-xl font-bold text-slate-800 mb-4\">Categor\303\255as / Bloques</h2>\n      \n      <form onSubmit={handleAdd} className=\"flex flex-col gap-3 mb-6\">\n        <div className=\"flex gap-2\">\n          <input \n            type=\"text\" \n            placeholder=\"Ej: Cocina, Sala, Nocturno...\" \n            value={name}\n            onChange={(e) => setName(e.target.value)}\n            className=\"flex-1 px-3 py-2 border border-slate-300 rounded focus:ring-2 focus:ring-emerald-500 outline-none\"\n          />\n          <button \n            type=\"submit\"\n            className=\"bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded flex items-center gap-2 transition-colors\"\n          >\n            <Plus size={18} />\n            A\303\261adir\n          </button>\n        </div>\n        <div className=\"flex gap-2 items-center flex-wrap\">\n          <span className=\"text-sm border-r pr-2 text-slate-500\">Color:</span>\n          {CATEGORY_COLORS.map(color => (\n            <button\n              key={color}\n              type=\"button\"\n              onClick={() => setSelectedColor(color)}\n              className={`w-6 h-6 rounded-full cursor-pointer transition-transform ${color} ${selectedColor === color ? \'ring-2 ring-offset-2 ring-slate-800 scale-110\' : \'hover:scale-110\'}`}\n              title=\"Seleccionar color\"\n            />\n          ))}\n        </div>\n      </form>\n\n      <div className=\"space-y-2 max-h-64 overflow-y-auto\">\n        {categories.length === 0 ? (\n          <p className=\"text-sm text-slate-500 italic text-center py-4\">No hay categor\303\255as registradas.</p>\n        ) : (\n          categories.map(cat => (\n            <div key={cat.id} className=\"flex justify-between items-center p-3 bg-slate-50 rounded border border-slate-100\">\n              <div className=\"flex items-center gap-2\">\n                <Tag className={`${cat.color.replace(\'bg-\', \'text-\')} fill-current`} size={16} />\n                <span className=\"font-medium text-slate-700\">{cat.name}</span>\n              </div>\n              <button \n                onClick={() => removeCategory(cat.id)}\n                className=\"text-red-500 hover:text-red-700 p-1 rounded hover:bg-red-50 transition-colors\"\n              >\n                <Trash2 size={18} />\n              </button>\n            </div>\n          ))\n        )}\n      </div>\n    </div>\n  );\n}\n"
    }
