        lines {
          text: "  const cleaned = val.replace(/[^\\d:]/g, \'\');"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  if (!cleaned) return \'\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  if (cleaned.includes(\':\')) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const parts = cleaned.split(\':\');"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    return `${parts[0].padStart(2, \'0\')}:${(parts[1] || \'00\').padStart(2, \'0\').slice(0, 2)}`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
