        lines {
          text: "                              const hrs = getHours(s.start, s.end);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                              rowHoursDecimals += hrs;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                              dailyCosts[d] += hrs * row.rate; // accumulate into global day total"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                           }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
