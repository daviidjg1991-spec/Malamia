        lines {
          text: "                      // Computations for row totals"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      let rowHoursDecimals = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      if (row.type === \'employee\') {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                         for (let d = 0; d < 10; d++) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
